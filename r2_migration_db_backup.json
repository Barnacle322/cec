    "old": "{\"time\": 1758600566412, \"blocks\": [{\"id\": \"QUECJIbfqW\", \"data\": {\"text\": \"Maker Fest 2025 в Мейкерспейс АУЦА\", \"level\": 2}, \"type\": \"header\"}, {\"id\": \"y1gcm9ORtl\", \"data\": {\"file\": {\"url\": \"https://mldc-pictures.fra1.cdn.digitaloceanspaces.com/afb14014-0a7d-4f37-8843-10afbf3a5612.jpg\"}, \"caption\": \"\", \"stretched\": false, \"withBorder\": false, \"withBackground\": false}, \"type\": \"image\"}, {\"id\": \"8pg3lCn_aL\", \"data\": {\"text\": \"<b>&nbsp;Maker Fest 2025: территория идей и вдохновения&nbsp;</b>\"}, \"type\": \"paragraph\"}, {\"id\": \"ggNiaOV1Pf\", \"data\": {\"text\": \"28 сентября в Makerspace Learning &amp; Design Center снова оживёт настоящий праздник креатива — Maker Fest.\"}, \"type\": \"paragraph\"}, {\"id\": \"s-vNj4lz8T\", \"data\": {\"text\": \"В этот день в одном пространстве соберутся студенты, мастера и новаторы, чтобы показать свои проекты, поделиться опытом и вдохновить друг друга. Атмосфера будет кипеть от энергии: 3D-принтеры, необычные мастер-классы, интерактивные активности, креативные решения и море общения.\"}, \"type\": \"paragraph\"}, {\"id\": \"h9J2PKPLMj\", \"data\": {\"text\": \"Maker Fest — это не просто выставка или занятие, это возможность почувствовать себя частью сообщества, где ценят смелые идеи и поддержку. Здесь рождаются проекты, которые способны менять будущее, а новые знакомства перерастают в дружбу и партнёрства.\"}, \"type\": \"paragraph\"}, {\"id\": \"nZvkDHzP4g\", \"data\": {\"text\": \"📍 Адрес: Аалы Токомбаева 7/7А\\n⏰ Дата: 28 сентября\"}, \"type\": \"paragraph\"}, {\"id\": \"dZpsBDORK3\", \"data\": {\"text\": \"Если ты любишь создавать и творить своими руками — приходи. Maker Fest ждёт именно тебя!\"}, \"type\": \"paragraph\"}], \"version\": \"2.31.0\"}"
  },
