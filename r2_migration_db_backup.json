    "old": "{\"time\": 1743506404628, \"blocks\": [{\"id\": \"jKAhv1bU0Q\", \"data\": {\"file\": {\"url\": \"https://mldc-pictures.fra1.cdn.digitaloceanspaces.com/8231b94d-2f81-45b3-87e7-dda61118fe57.jpg\"}, \"caption\": \"\", \"stretched\": false, \"withBorder\": false, \"withBackground\": false}, \"type\": \"image\"}, {\"id\": \"HysqxdSJBm\", \"data\": {\"text\": \"На этом мероприятии вы сможете:\"}, \"type\": \"paragraph\"}, {\"id\": \"5r2NuWhJCZ\", \"data\": {\"text\": \"✨ Ознакомиться с нашим оборудованием и технологиями: 3D-принтеры, лазерные резаки, электроника и многое другое.\"}, \"type\": \"paragraph\"}, {\"id\": \"OmxCpdOE_3\", \"data\": {\"text\": \"✨ Пообщаться с нашими наставниками и экспертами.\"}, \"type\": \"paragraph\"}, {\"id\": \"e_QZFqVjgw\", \"data\": {\"text\": \"✨ Принять участие в мастер-классах и маленьких проектах.\"}, \"type\": \"paragraph\"}, {\"id\": \"L2FwpafMWd\", \"data\": {\"text\": \"✨ Узнать, как стать частью сообщества и использовать MakerSpace для реализации своих идей.\"}, \"type\": \"paragraph\"}, {\"id\": \"B1gjCSctUL\", \"data\": {\"text\": \"Мы открыты для всех, независимо от уровня подготовки — будь вы новичок или опытный разработчик.\"}, \"type\": \"paragraph\"}, {\"id\": \"h_EHb8QQbX\", \"data\": {\"text\": \"Не пропустите шанс увидеть, как технологии меняют мир, и вдохновитесь на новые достижения!\"}, \"type\": \"paragraph\"}, {\"id\": \"kbYAPMkRFM\", \"data\": {\"text\": \"Вход свободный.\"}, \"type\": \"paragraph\"}], \"version\": \"2.31.0-rc.7\"}"
  },
